        "plt.show()\n",
        "\n",
        "print(\"\\n2D Visualization Summary:\")\n",
        "print(\"- Left column: PCA projection of input features colored by true class\")\n",
        "print(\"- Right column: Confusion matrices showing prediction accuracy per class\")\n"
