        "    \n",
        "    ax.set_xlabel('Predicted')\n",
        "    ax.set_ylabel('True')\n",
        "    accuracy = (y_pred == y_true).mean()\n",
        "    ax.set_title(f'{name} Confusion Matrix (Acc: {accuracy:.3f})')\n",
        "\n",
