      "text": "//wNum\u003d0         -last two parameters are obsolete\ncreateKnownByRelation(vmResult,wNum,rCounter,0,0);\n\npsInsert \u003d conn.prepareStatement(\" MATCH (d:Dnode), (k:CreatedBy) WHERE d.vmResult\u003d? AND k.resultId\u003d? AND k.wNum\u003d? AND k.translateIndex\u003d? AND k.pArrayIndexValue\u003d? WITH d,k MERGE  (d)-[ee:CreatedBye]-\u003e(k)\");\n\n",
