      "title": "determined \u003d1 when totalZero \u003d f(wNum) ",
      "text": "MATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:0})\nWITH  CASE WHEN k.wNum\u003d0 THEN CASE WHEN d.totalZero\u003d5 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin\n\nMATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:1})\nWITH  CASE WHEN k.wNum\u003d1 THEN CASE WHEN d.totalZero\u003d4 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin\n \nMATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:2})\nWITH  CASE WHEN k.wNum\u003d2 THEN CASE WHEN d.totalZero\u003d3 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin \n\nMATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:3})\nWITH  CASE WHEN k.wNum\u003d3 THEN CASE WHEN d.totalZero\u003d2 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin\n\nMATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:4})\nWITH  CASE WHEN k.wNum\u003d4 THEN CASE WHEN d.totalZero\u003d1 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin\n\nMATCH (d:Dnode)-[ee:CreatedBye]-\u003e(k:CreatedBy {wNum:5})\nWITH  CASE WHEN k.wNum\u003d5 THEN CASE WHEN d.totalZero\u003d0 THEN 1 ELSE 0 END ELSE 2 END as determin,d,k\nSET d.determined\u003ddetermin\nRETURN d.totalZero,k.wNum,determin",
