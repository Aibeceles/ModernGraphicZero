      "text": "%spark\n\nimport scala.collection.mutable.ArrayBuffer\nimport org.apache.spark.sql.{DataFrame,Dataset}\n\n//https://alvinalexander.com/scala/scala-factorial-recursion-example-recursive-programming/\n\nobject Combinations {\n\n    def factorial(n: Int): Int \u003d n match {\n        case 0 \u003d\u003e 1\n        case _ \u003d\u003e n * factorial(n-1)\n    }\n\n    def main(args: Array[String]) {\n \n        val terms \u003d new ArrayBuffer[combinations]()\n        val numElements \u003d BigInt(args(0)).intValue()  \n        val numElementsFact \u003d factorial(numElements)\n        for(a \u003c- 0 to numElements) {   \n        terms +\u003d  combinations(numElements.toString,a.toString,(numElementsFact/(factorial(numElements-a)*factorial(a))).toString)\n        }\n        println(factorial(5))\n\n        val df \u003d spark.createDataFrame(terms)\n        val dfCount \u003d df.count()\n        df.show(dfCount.toInt,false)\n        z.put(args(1),df)\n\n    }\n}\n",
