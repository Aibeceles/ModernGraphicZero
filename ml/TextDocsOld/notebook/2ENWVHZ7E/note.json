      "text": "%neo4j\nMATCH (i:IndexedBy)-[]-\u003e(e:Evaluate),\n      (i:IndexedBy)-[:VertexIndexedBy]-\u003e(pp:ProductArgsNode)-[pR1:ProductRelationT|ProductRelationA]-\u003e(p:ProductArgsNode),\n      (ii:IndexedBy)-[:VertexIndexedBy]-\u003e(p:ProductArgsNode)\n\nWHERE i.N\u003d\u00275\u0027 AND i.MaxN\u003d\u00276\u0027 AND i.Dimension\u003d\"8\" AND i.RowCounter\u003d8 //  AND p.Divisor\u003d4\n//WHERE i.N\u003d${N} AND i.MaxN\u003d\u00276\u0027 AND i.Dimension\u003d\"8\" AND i.RowCounter\u003dnoteRowCounter\nWITH i,e,p,i.N as iN, i.MaxN as iM,pp,pR1.T as pR1T,pp.Divisor as ppD1,pR1.Eval as pR1E\nMATCH (v:VertexNode) \u003c- [p1:ProductRelationT] - (p) \nWITH i,e,p,v,p1,iN,iM,pp,pR1T,pp.Divisor as pD1,pR1E,p1.T as p1TT,ppD1 \nOPTIONAL MATCH  (p) - [p2:ProductRelationA ] -\u003e (vv:VertexNode)\nWITH i,e,p,v,p1,p2,vv,iN,iM,p.Divisor as pD,pp,pR1T,pR1E,ppD1, p1TT,p2.T as p2TT,p2.Eval as p2EE\nRETURN i,e,p,v,vv",
