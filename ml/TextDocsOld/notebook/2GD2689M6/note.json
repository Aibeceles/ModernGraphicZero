      "text": "object QwNumQuery {\n\nimport differenceScripts.DiffDFScripts\nimport scala.collection.mutable.ArrayBuffer\n\ndef wNumQuery(wNum:Int,dfs:DiffDFScripts): ArrayBuffer[dNFieldsWSkip] \u003d {\n\nval terms \u003d new ArrayBuffer[dNFieldsWSkip]()\nval dfsRS \u003d dfs.wNumQQ(wNum)\nwhile (dfsRS.next()) {\nterms +\u003d dNFieldsWSkip(BigInt(dfsRS.getString(1)).intValue(),BigInt(dfsRS.getString(2)).intValue(),BigInt(dfsRS.getString(3)).intValue())\n}\nterms\n}\n\ndef main(args:Array[String]) {\nval dfs \u003d new DiffDFScripts\nval terms \u003d new ArrayBuffer[ArrayBuffer[dNFieldsWSkip]]()\nval wNum \u003d BigInt(args(0)).intValue()                             \nprintln(\"after wNum\")\nfor(a \u003c- 0 to wNum) {\n   terms +\u003d wNumQuery(a,dfs)\n}\nval mainTermss\u003dterms.flatMap(_.toList)\nval df \u003d spark.createDataFrame(mainTermss)\nval dfCount \u003d df.count()\ndf.show(dfCount.toInt,false)\nz.put(args(1),df)\n//dfss.endConn()\n}\n}\n\n\n\n",
