      "text": "object QuerryS3T {\n  \nimport zadscripts.DFScripts\nimport scala.collection.mutable.ArrayBuffer\nimport scala.math.BigDecimal\nimport org.apache.spark.sql.types.DecimalType\n\ndef s3TQuerry(rLow:String,rHigh:String,nMax:String,d1:String,d2:String,d3:String,tC:Int): ArrayBuffer[s3T]  \u003d {\n\nval terms \u003d new ArrayBuffer[s3T]()\nval s3 \u003d new DFScripts  \nval s3RS \u003d s3.s3T(rLow,rHigh,nMax,d1,d2,d3,tC)\nwhile (s3RS.next()) {                       \nval scalar \u003d BigDecimal(s3RS.getString(3))\nval degree \u003d s3RS.getString(2).toInt\nval divisor \u003d BigDecimal(s3RS.getString(6))\nval index \u003d BigDecimal(s3RS.getString(5))\nval indexPower \u003d index.pow(degree)\nval scalarDiv \u003d scalar/divisor\nval result \u003d  indexPower * scalarDiv\n\nprintln(s3T(s3RS.getString(1),degree,s3RS.getString(3),s3RS.getString(4),index,divisor,s3RS.getString(7),result.bigDecimal.toPlainString)+\" \"+\"\\n\")\nterms +\u003d s3T(s3RS.getString(1),degree,s3RS.getString(3),s3RS.getString(4),index,divisor,s3RS.getString(7),result.bigDecimal.toPlainString)\n}\n// val termsSeq \u003d terms.toSeq\n//println(termsSeq)\n//val resultSeq \u003d termsSeq.map(_.result)           \n//val resultSeqBD \u003d resultSeq.collect{ case x:String \u003d\u003e BigDecimal(x) }\n//println(resultSeqBD)                              \n//resultSeqBD.reduce(_+_)\nterms\n}\ndef main(args:Array[String]) {\n\n  val terms \u003d new ArrayBuffer[rResult]()\n  val nMax \u003d \"1000\"                                 \n  val a \u003d 3                                     //  a iterates over dimension n iterates over range  b iterates over tConstraint\n  val n \u003d 7                                    \n         \nval mainTerms \u003d List.range(0, n-1) flatMap (b \u003d\u003e QuerryS3T.s3TQuerry(n.toString,n.toString,nMax,BigDecimal(2).pow(a+1).toString(),BigDecimal(2).pow(a).toString(),BigDecimal(2).pow(a).toString(),BigDecimal(2).pow(b).toInt)) \n\n//println(mainTerms)\nval mainTermss\u003dmainTerms.toSeq\nprintln(mainTermss+\" \"+\"\\n\")\nval df \u003d spark.createDataFrame(mainTermss)\n\nval dfCount \u003d df.count()\ndf.show(dfCount.toInt,false)\nz.put(\"s12DF\",df)\n}\n}",
