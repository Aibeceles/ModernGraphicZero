      "dateCreated": "2021-04-23 09:10:05.484",
      "status": "READY",
      "progressUpdateIntervalMs": 500
    },
    {
      "text": "MATCH (c:CreatedBy {wNum:4}) WITH c.pArray as pArrayS,c\nWITH split(substring(pArrayS, 1, size(pArrayS)-2), \u0027,\u0027) as pArrayN,c\nWITH [str in pArrayN | toInteger(trim(str))] as pArrayNN,c\n//WITH CASE WHEN pArrayNN[size(pArrayNN)-2]\u003d4 THEN c End as cc\nWITH CASE WHEN pArrayNN[size(pArrayNN)-2] IN [1, 2, 3] THEN c End as cc\nWITH cc WHERE cc IS NOT null \n//return cc\nMATCH (cc:CreatedBy)\u003c-[r:CreatedBye]-(d) RETURN d\n",
      "user": "anonymous",
