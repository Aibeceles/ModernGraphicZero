    {
      "title": "Train/Test Split ",
      "text": "MATCH (c:CreatedBy {wNum:5})\u003c-[r:CreatedBye]-(d) - [:zMap*1..2] -\u003e (dd) RETURN d,dd      //- real dicey memory wise.",
      "user": "anonymous",
      "dateUpdated": "2021-04-26 11:04:43.376",
      "config": {
        "colWidth": 12.0,
        "fontSize": 9.0,
