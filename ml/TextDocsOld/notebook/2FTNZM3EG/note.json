    {
      "title": "N,MaxN,D parameter querries to DFScripts.s3T.  The ResultSets populate a DataFrame of s3TQu case classes.  DataFrame is persisted to z context.",
      "text": "object QuerryS3T {\n  \nimport zadscripts.DFScripts\nimport scala.collection.mutable.ArrayBuffer\nimport scala.math.BigDecimal\nimport org.apache.spark.sql.types.DecimalType\n\ndef s3TQuerry(rLow:String,rHigh:String,nMax:String,d1:String,d2:String,d3:String,tC:Int): ArrayBuffer[s3TQu] \u003d {\n\nval terms \u003d new ArrayBuffer[s3TQu]()\nval s3 \u003d new DFScripts  \nval s3RS \u003d s3.s3T(rLow,rHigh,nMax,d1,d2,d3,tC)\n\nwhile (s3RS.next()) {                       \nterms +\u003d s3TQu(s3RS.getString(1),s3RS.getString(2),s3RS.getString(3),s3RS.getString(4),s3RS.getString(5),s3RS.getString(6),s3RS.getString(7))\n}\nterms\n}\n\ndef main(args:Array[String]) {\ntype TTupple \u003d Tuple2[ArrayBuffer[s3TQu],BigDecimal]\nval terms \u003d new ArrayBuffer[rResult]()\nval nMax \u003d \"1000\"                                 \nval a \u003d 2                                          \nval n \u003d 7                                          \nval mainTerms \u003d List.range(0, n-1) flatMap (b \u003d\u003e QuerryS3T.s3TQuerry(n.toString,n.toString,nMax,BigDecimal(2).pow(a+1).toString(),BigDecimal(2).pow(a).toString(),BigDecimal(2).pow(a).toString(),BigDecimal(2).pow(b).toInt)) \n\n//val mainTermss\u003dmainTerms.toSeq\n//println(mainTermss+\" \"+\"\\n\")\nval df \u003d spark.createDataFrame(mainTerms.toSeq)\nval dfCount \u003d df.count()\ndf.show(dfCount.toInt,false)\nz.put(\"s12DF\",df)\n}\n}",
