      "text": "%spark\nobject QuerryS3T {\n  \nimport zadscripts.DFScripts\nimport scala.collection.mutable.ArrayBuffer\nimport scala.math.BigDecimal\n\ncase class s3T(dimension:String,Degree:Int,scalar:BigDecimal,index:String,maxIndex:BigDecimal,divisor:BigDecimal,rowCounter:String,result:String)\n\n def s3TQuerry(rLow:String,rHigh:String,nMax:String,d1:String,d2:String,d3:String,tC:Int):BigDecimal  \u003d {\n\n  val terms \u003d new ArrayBuffer[s3T]()\n  val s3 \u003d new DFScripts  \n     \n  val s3RS \u003d s3.s3T(rLow,rHigh,nMax,d1,d2,d3,tC)\n  while (s3RS.next()) {\n  val scalar \u003d BigDecimal(s3RS.getString(3))\n  val degree \u003d s3RS.getString(2).toInt\n  val divisor \u003d BigDecimal(s3RS.getString(6))\n  val index \u003d BigDecimal(s3RS.getString(5))\n  val indexPower \u003d index.pow(degree)\n  val scalarDiv \u003d scalar/divisor\n  val result \u003d  indexPower * scalarDiv\n  print(result + \"    \")\n  terms +\u003d s3T(s3RS.getString(1),  degree,   scalar,    s3RS.getString(4),    index    ,   divisor   ,   s3RS.getString(7)  ,   result.toString)\n  \n  }\n  val termsSeq \u003d terms.toSeq\n  println(termsSeq)\n  val resultSeq \u003d termsSeq.map(_.result)            \n  val resultSeqBD \u003d resultSeq.collect{ case x:String \u003d\u003e BigDecimal(x) }\n  println(resultSeqBD)                              \n  resultSeqBD.reduce(_+_)\n}\n  \ndef main(args:Array[String]) {   \nval rLow:String \u003d \"4\"                             //\u003e rLow  : String \u003d 4\nval rHigh \u003d \"4\"                                   //\u003e rHigh  : String \u003d 4\nval nMax \u003d \"1000\"                                 //\u003e nMax  : String \u003d 1000\nval d1 \u003d \"8\"                                      //\u003e d1  : String \u003d 4\nval d2 \u003d \"8\"                                      //\u003e d2  : String \u003d 4\nval d3 \u003d \"8\"                                      //\u003e d3  : String \u003d 4\nval x \u003d (0 to 2).map { e \u003d\u003e QuerryS3T.s3TQuerry(rLow:String,rHigh:String,nMax:String,d1:String,d2:String,d3:String,BigDecimal(2).pow(e).toInt)  }\nprintln(x)\n}\n}",
