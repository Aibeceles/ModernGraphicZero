      "text": "%neo4j\n\nMATCH (v:VertexNode) \u003c-[pR:ProductRelationT] -  (p:ProductArgsNode)\u003c-[]-(i:IndexedBy)-[]-\u003e(e:Evaluate) \n      where i.N\u003d\"${iN}\" AND i.MaxN\u003d\"${iMaxN}\" AND i.Dimension\u003d\"4\" \nWITH i.N as iN, i.MaxN as iM,e,p, pR.T as t                          \nOPTIONAL MATCH (pp:ProductArgsNode)\u003c-[]- (ii:IndexedBy)-[]-\u003e(ee:Evaluate {Value:toString(t)})\n      where ii.MaxN\u003d\"${iiMaxN}\"  AND ii.Dimension\u003d\"4\"  // and ee.Value\u003d\"4\" \nWITH  iN,iM,e,p,pp,t,ee\nCREATE (ppp:ProductArgsNode {Divisor:t,Dimension:\"4\"}) \nFOREACH(snoreMe IN CASE  WHEN pp IS null  THEN [1] ELSE [] END | \nCREATE (p) \u003c- [:ProductRelationT {T:1}] - (ppp) )\nFOREACH(snoreMe IN CASE  WHEN pp IS not null  THEN [1] ELSE [] END | \nCREATE (p) \u003c- [:ProductRelationT {T:t}] - (ppp)    \nCREATE (ppp) - [:ProductRelationA {T:t, Eval:ee.Value}] -\u003e (pp)  )\nMERGE  (i:IndexedBy {N:iN, Dimension:\"8\",MaxN:iM,RowCounter:t})\nMERGE  (i)-[:VertexIndexedBy]-\u003e(ppp)\nMERGE (i) -[:IndexedByEvaluate]-\u003e(e)\nreturn  count(ppp)\n",
