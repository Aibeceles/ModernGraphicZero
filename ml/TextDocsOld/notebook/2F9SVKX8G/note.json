      "text": "UNWIND range(7,7) AS n\nWITH toString(n) AS N, \u002730\u0027 as nMax\nMATCH (v:VertexNode)\u003c-[vI:VertexIndexedBy]-(i:IndexedBy {N:N,MaxN:nMax,Dimension:\u00278\u0027,RowCounter:32})-[]-\u003e(e:Evaluate)\nWITH i.N as iN, i.MaxN as iM,e,v,vI,i                        \nOPTIONAL MATCH (vv:VertexNode)\u003c-[vII:VertexIndexedBy]-(ii:IndexedBy {N:\u00277\u0027,MaxN:\u002710\u0027,Dimension:\u00278\u0027,RowCounter:32})-[]-\u003e(e:Evaluate)\nWITH vI.twoSeq AS vTwoSeq,iN,iM,v.Scalar AS vScalar ,vI.divisor AS vIDivisor,vII.divisor AS vIIDivisor,vv.Scalar AS vvScalar,vv.Degree AS vvDegree,v.Degree AS vDegree\n\nRETURN CASE WHEN vvScalar IS Null THEN apoc.number.exact.div(vScalar,vIDivisor) ELSE apoc.number.exact.mul(apoc.number.exact.div(vScalar,vIDivisor),apoc.number.exact.div(vvScalar,vIIDivisor)) END AS scalarProduct,\n     iN,iM,CASE WHEN vvDegree IS Null THEN \u00270\u0027 ELSE vvDegree END AS vvDegree,vDegree\n",
